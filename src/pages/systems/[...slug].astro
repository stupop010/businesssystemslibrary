---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const systems = await getCollection('systems');
  return systems.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Resolve related-system slugs to their titles for the cross-link block.
const all = await getCollection('systems');
const related = entry.data.relatedSystems
  .map((slug) => all.find((s) => s.id === slug))
  .filter((s) => s !== undefined);

const updated = entry.data.updated.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <p class="eyebrow">{entry.data.category}</p>
    <h1>{entry.data.title}</h1>
    {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
    <p class="meta">
      {entry.data.status === 'draft' && <span class="badge">Draft</span>}
      Last updated {updated}
    </p>

    <Content />

    {
      related.length > 0 && (
        <section class="related">
          <h2>Related systems</h2>
          <ul class="system-list">
            {related.map((s) => (
              <li>
                <a href={`/systems/${s.id}/`}>{s.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>
